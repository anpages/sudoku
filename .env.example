# Neon Serverless Postgres
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=cambia_esto_por_32_chars_random
BETTER_AUTH_URL=https://tu-dominio.vercel.app

# Google OAuth (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anti-cheat HMAC secret (diferente de BETTER_AUTH_SECRET)
PUZZLE_HMAC_SECRET=cambia_esto_por_32_chars_random

# Vercel Cron secret
CRON_SECRET=cambia_esto_por_token_secreto

# Frontend (leave empty in dev — Vite proxy handles /api)
VITE_API_URL=
